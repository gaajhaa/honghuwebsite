        // 数据归一化：对旧版本数据补全缺失字段，避免运行时 undefined
        function normalizeData(data) {
            if (!data || typeof data !== 'object') return JSON.parse(JSON.stringify(defaultData));
            // banners 与 products 至少要是数组
            data.banners = Array.isArray(data.banners) ? data.banners : [];
            data.products = Array.isArray(data.products) ? data.products : [];
            // 每个 product 补全 poster / features / featuresDetail
            data.products.forEach((p) => {
                if (typeof p.poster === 'undefined') p.poster = '';
                if (!Array.isArray(p.features)) p.features = [];
                if (!Array.isArray(p.featuresDetail)) p.featuresDetail = [];
                if (!p.description) p.description = '';
                if (!p.image) p.image = '';
            });
            // company 补全
            if (!data.company || typeof data.company !== 'object') {
                data.company = JSON.parse(JSON.stringify(defaultData.company));
            } else {
                const dc = defaultData.company;
                const c = data.company;
                for (const k of Object.keys(dc)) {
                    if (typeof c[k] === 'undefined') {
                        c[k] = Array.isArray(dc[k]) ? JSON.parse(JSON.stringify(dc[k])) : dc[k];
                    }
                }
                if (!Array.isArray(c.stats)) c.stats = [];
            }
            return data;
        }

        // 获取数据
        function getData() {
            const stored = localStorage.getItem('hh_website_content');
            if (stored) {
                try {
                    const parsed = JSON.parse(stored);
                    return normalizeData(parsed);
                } catch (e) {
                    return JSON.parse(JSON.stringify(defaultData));
                }
            }
            return JSON.parse(JSON.stringify(defaultData));
        }

        // 保存数据
        function saveData(data, silent) {
            try {
                localStorage.setItem('hh_website_content', JSON.stringify(data));
                return true;
            } catch (err) {
                console.error('保存失败：', err);
                if (!silent) {
                    const size = checkDataSize(data);
                    alert(
                        '保存失败：本地存储空间不足。\n\n' +
                        '当前要保存的数据大小约为 ' + size.mb.toFixed(2) + ' MB，' +
                        '而浏览器通常为单域名提供约 5MB 的本地存储。\n\n' +
                        '建议：\n' +
                        '1. 使用更小/更清晰的图片；\n' +
                        '2. 删除不需要的旧产品或Banner；\n' +
                        '3. 点击"重置数据"清理存储后再上传。'
                    );
                }
                return false;
            }
        }

        // 检查登录
        function checkLogin() {
            const session = localStorage.getItem('hh_admin_session');
            if (!session) {
                window.location.href = 'admin-login.html';
                return;
            }
            try {
                const data = JSON.parse(session);
                if (data.expiresAt < Date.now()) {
                    localStorage.removeItem('hh_admin_session');
                    window.location.href = 'admin-login.html';
                }
            } catch (e) {
                window.location.href = 'admin-login.html';
            }
        }

        // 退出登录
        function logout() {
            localStorage.removeItem('hh_admin_session');
            window.location.href = 'admin-login.html';
        }

        // 显示面板
        function showPanel(name, evt) {
            try {
                document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
                document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
                document.getElementById('panel-' + name).classList.add('active');
                if (evt && evt.currentTarget) {
                    evt.currentTarget.classList.add('active');
                }
                if (name === 'dashboard') updateDashboard();
                if (name === 'banners') renderBanners();
                if (name === 'products') renderProducts();
                if (name === 'company') loadCompanyForm();
            } catch (err) {
                console.error('切换面板失败：', err);
                alert('切换面板失败：' + err.message);
            }
        }

        // 更新仪表盘
        function updateDashboard() {
            const data = getData();
            document.getElementById('statBanners').textContent = data.banners.length;
            document.getElementById('statProducts').textContent = data.products.length;
        }

        // 渲染Banners
        function renderBanners() {
            const data = getData();
            const tbody = document.getElementById('bannersTable');
            tbody.innerHTML = data.banners.map(b => `
                <tr>
                    <td><img src="${b.image}" alt="${b.title}"></td>
                    <td>${b.title}</td>
                    <td>${b.subtitle}</td>
                    <td>
                        <button class="btn btn-primary btn-sm" onclick="editBanner(${b.id})">编辑</button>
                        <button class="btn btn-danger btn-sm" onclick="deleteBanner(${b.id})">删除</button>
                    </td>
                </tr>
            `).join('');
        }

        // Banner弹窗
        function openBannerModal(id = null) {
            document.getElementById('bannerModal').classList.add('active');
            document.getElementById('bannerForm').reset();
            document.getElementById('bannerImagePreview').style.display = 'none';
            document.getElementById('bannerId').value = '';
            document.getElementById('bannerModalTitle').textContent = '添加Banner';
            
            if (id) {
                const data = getData();
                const banner = data.banners.find(b => b.id === id);
                if (banner) {
                    document.getElementById('bannerId').value = banner.id;
                    document.getElementById('bannerImage').value = banner.image;
                    document.getElementById('bannerImagePreview').src = banner.image;
                    document.getElementById('bannerImagePreview').style.display = 'block';
                    document.getElementById('bannerTitle').value = banner.title;
                    document.getElementById('bannerSubtitle').value = banner.subtitle;
                    document.getElementById('bannerLink').value = banner.link;
                    document.getElementById('bannerModalTitle').textContent = '编辑Banner';
                }
            }
        }

        function closeBannerModal() {
            document.getElementById('bannerModal').classList.remove('active');
        }

        function editBanner(id) { openBannerModal(id); }

        function deleteBanner(id) {
            if (confirm('确定要删除这个Banner吗？')) {
                const data = getData();
                data.banners = data.banners.filter(b => b.id !== id);
                saveData(data);
                renderBanners();
            }
        }

        function handleBannerImageUpload(event) {
            handleImageUpload(event, {
                compressFn: compressBanner,
                previewId: 'bannerImagePreview',
                hiddenId: 'bannerImage'
            });
        }

        // Banner表单提交
        document.getElementById('bannerForm').addEventListener('submit', function(e) {
            e.preventDefault();
            try {
                const data = getData();
                const id = document.getElementById('bannerId').value;
                const hiddenImg = document.getElementById('bannerImage').value;
                const title = document.getElementById('bannerTitle').value || '';
                const subtitle = document.getElementById('bannerSubtitle').value || '';
                const link = document.getElementById('bannerLink').value || '#products';

                // 如果是编辑，用户没有重新上传图片，则保留原图片
                let imageToUse = hiddenImg;
                if (id) {
                    const old = data.banners.find(function (b) { return b.id === parseInt(id, 10); });
                    if (old && !imageToUse) {
                        imageToUse = old.image || '';
                    }
                }
                if (!imageToUse) {
                    alert('请先上传Banner图片');
                    return;
                }

                const banner = {
                    id: id ? parseInt(id, 10) : Date.now(),
                    image: imageToUse,
                    title: title,
                    subtitle: subtitle,
                    link: link
                };

                if (id) {
                    const index = data.banners.findIndex(b => b.id === parseInt(id, 10));
                    if (index === -1) data.banners.push(banner);
                    else data.banners[index] = banner;
                } else {
                    data.banners.push(banner);
                }

                const sizeInfo = checkDataSize(data);
                if (sizeInfo.exceed) {
                    if (!confirm(
                        '当前整个站点（含所有 Banner、产品图、海报、Logo）的存储大小约为 ' +
                        sizeInfo.mb.toFixed(2) + ' MB。\n\n' +
                        '浏览器单域名的 localStorage 上限约为 5MB。\n' +
                        '（注：图片以 base64 存储会比原文件大 ~1.33 倍，且是整体存储，不是单张图片）\n\n' +
                        '是否仍然继续保存？'
                    )) {
                        return;
                    }
                }

                const ok = saveData(data);
                if (!ok) {
                    return;
                }
                closeBannerModal();
                renderBanners();
                alert('Banner已保存！');
            } catch (err) {
                console.error(err);
                alert('保存Banner失败：' + err.message);
            }
        });

        // 渲染产品
        function renderProducts() {
            const data = getData();
            const tbody = document.getElementById('productsTable');
            tbody.innerHTML = data.products.map(p => `
                <tr>
                    <td><img src="${p.image}" alt="${p.title}"></td>
                    <td>${p.title}</td>
                    <td>${p.destination}</td>
                    <td>${p.price}</td>
                    <td>${p.days}</td>
                    <td>
                        <button class="btn btn-primary btn-sm" onclick="editProduct(${p.id})">编辑</button>
                        <button class="btn btn-danger btn-sm" onclick="deleteProduct(${p.id})">删除</button>
                    </td>
                </tr>
            `).join('');
        }

        // 产品弹窗
        let productTags = [];

        function openProductModal(id = null) {
            document.getElementById('productModal').classList.add('active');
            document.getElementById('productForm').reset();
            document.getElementById('productImagePreview').style.display = 'none';
            document.getElementById('posterImagePreview').style.display = 'none';
            document.getElementById('posterImage').value = '';
            document.getElementById('productId').value = '';
            document.getElementById('productModalTitle').textContent = '添加产品';
            productTags = [];
            renderProductTags();
            
            if (id) {
                const data = getData();
                const product = data.products.find(p => p.id === id);
                if (product) {
                    document.getElementById('productId').value = product.id;
                    document.getElementById('productImage').value = product.image;
                    document.getElementById('productImagePreview').src = product.image;
                    document.getElementById('productImagePreview').style.display = 'block';
                    if (product.poster) {
                        document.getElementById('posterImage').value = product.poster;
                        document.getElementById('posterImagePreview').src = product.poster;
                        document.getElementById('posterImagePreview').style.display = 'block';
                    }
                    document.getElementById('productTitle').value = product.title;
                    document.getElementById('productDestination').value = product.destination;
                    document.getElementById('productPrice').value = product.price;
                    document.getElementById('productDays').value = product.days;
                    document.getElementById('productDesc').value = product.description;
                    document.getElementById('productFeaturesDetail').value = (product.featuresDetail || []).join('\n');
                    productTags = [...(product.features || [])];
                    renderProductTags();
                    document.getElementById('productModalTitle').textContent = '编辑产品';
                }
            }
        }

        function closeProductModal() {
            document.getElementById('productModal').classList.remove('active');
        }

        function editProduct(id) { openProductModal(id); }

        function deleteProduct(id) {
            if (confirm('确定要删除这个产品吗？')) {
                const data = getData();
                data.products = data.products.filter(p => p.id !== id);
                saveData(data);
                renderProducts();
            }
        }

        function handleProductImageUpload(event) {
            handleImageUpload(event, {
                compressFn: compressProduct,
                previewId: 'productImagePreview',
                hiddenId: 'productImage'
            });
        }

        // 海报图片上传
        function handlePosterImageUpload(event) {
            handleImageUpload(event, {
                compressFn: compressPoster,
                previewId: 'posterImagePreview',
                hiddenId: 'posterImage'
            });
        }

        function renderProductTags() {
            const container = document.getElementById('productTagsInput');
            const input = container.querySelector('input');
            container.innerHTML = '';
            productTags.forEach((tag, index) => {
                container.innerHTML += `<span class="tag">${tag} <span onclick="removeTag(${index})">×</span></span>`;
            });
            container.appendChild(input);
        }

        function addTag(event, type) {
            if (event.key === 'Enter') {
                event.preventDefault();
                const value = event.target.value.trim();
                if (value && type === 'productTags' && !productTags.includes(value)) {
                    productTags.push(value);
                    renderProductTags();
                    event.target.value = '';
                }
            }
        }

        function removeTag(index) {
            productTags.splice(index, 1);
            renderProductTags();
        }

        // 产品表单提交
        document.getElementById('productForm').addEventListener('submit', function(e) {
            e.preventDefault();
            try {
                const data = getData();
                const id = document.getElementById('productId').value;
                const featuresDetail = document.getElementById('productFeaturesDetail').value
                    .split('\n').map(function (f) { return f.trim(); }).filter(Boolean);

                // 编辑时若未重新上传图片，保留原图片
                let imgToUse = document.getElementById('productImage').value;
                let posterToUse = document.getElementById('posterImage').value;
                if (id) {
                    const old = data.products.find(function (p) { return p.id === parseInt(id, 10); });
                    if (old) {
                        if (!imgToUse) imgToUse = old.image || '';
                        if (!posterToUse) posterToUse = old.poster || '';
                    }
                }

                const title = document.getElementById('productTitle').value;
                if (!title) {
                    alert('请填写产品名称');
                    return;
                }

                const product = {
                    id: id ? parseInt(id, 10) : Date.now(),
                    image: imgToUse,
                    poster: posterToUse,
                    title: title,
                    destination: document.getElementById('productDestination').value || '',
                    price: document.getElementById('productPrice').value || '',
                    days: document.getElementById('productDays').value || '',
                    features: productTags,
                    description: document.getElementById('productDesc').value || '',
                    featuresDetail: featuresDetail
                };

                if (id) {
                    const index = data.products.findIndex(function (p) { return p.id === parseInt(id, 10); });
                    if (index === -1) data.products.push(product);
                    else data.products[index] = product;
                } else {
                    data.products.push(product);
                }

                const sizeInfo = checkDataSize(data);
                if (sizeInfo.exceed) {
                    if (!confirm(
                        '当前整个站点（含所有 Banner、产品图、海报、Logo）的存储大小约为 ' +
                        sizeInfo.mb.toFixed(2) + ' MB。\n\n' +
                        '浏览器单域名的 localStorage 上限约为 5MB。\n' +
                        '（注：图片以 base64 存储会比原文件大 ~1.33 倍，且是整体存储，不是单张图片）\n\n' +
                        '是否仍然继续保存？'
                    )) {
                        return;
                    }
                }

                const ok = saveData(data);
                if (!ok) {
                    return;
                }
                closeProductModal();
                renderProducts();
                alert('产品已保存！');
            } catch (err) {
                console.error(err);
                alert('保存产品失败：' + err.message);
            }
        });

        // 加载公司表单
        function loadCompanyForm() {
            const data = getData();
            document.getElementById('companyName').value = data.company.name;
            document.getElementById('companyPhone').value = data.company.phone;
            document.getElementById('companyEmail').value = data.company.email;
            document.getElementById('companyHours').value = data.company.businessHours;
            document.getElementById('companyAddress').value = data.company.address;
            document.getElementById('companyDesc').value = data.company.description;
            
            if (data.company.aboutImage) {
                document.getElementById('aboutImagePreview').src = data.company.aboutImage;
                document.getElementById('aboutImagePreview').style.display = 'block';
            }

            // 加载 logo 和二维码预览
            if (data.company.logo) {
                document.getElementById('logoPreview').src = data.company.logo;
                document.getElementById('logoPreview').style.display = 'block';
            }
            if (data.company.wechatQr) {
                document.getElementById('wechatQrPreview').src = data.company.wechatQr;
                document.getElementById('wechatQrPreview').style.display = 'block';
            }
            if (data.company.videoQr) {
                document.getElementById('videoQrPreview').src = data.company.videoQr;
                document.getElementById('videoQrPreview').style.display = 'block';
            }
            
            renderStatsEditor(data.company.stats || []);
        }

        function renderStatsEditor(stats) {
            const container = document.getElementById('statsEditor');
            container.innerHTML = stats.map((s, i) => `
                <div style="display: flex; gap: 1rem; margin-bottom: 1rem;">
                    <input type="text" value="${s.number}" placeholder="数值（如：10+）" style="flex: 1; padding: 10px; border: 1px solid #ddd; border-radius: 6px;" onchange="updateStat(${i}, 'number', this.value)">
                    <input type="text" value="${s.label}" placeholder="标签（如：年行业经验）" style="flex: 2; padding: 10px; border: 1px solid #ddd; border-radius: 6px;" onchange="updateStat(${i}, 'label', this.value)">
                    <button class="btn btn-danger btn-sm" onclick="removeStat(${i})">删除</button>
                </div>
            `).join('');
        }

        function updateStat(index, field, value) {
            const data = getData();
            data.company.stats[index][field] = value;
            saveData(data);
        }

        function removeStat(index) {
            const data = getData();
            data.company.stats.splice(index, 1);
            saveData(data);
            renderStatsEditor(data.company.stats);
        }

        function addStat() {
            const data = getData();
            data.company.stats.push({ number: '0', label: '新统计项' });
            saveData(data);
            renderStatsEditor(data.company.stats);
        }

        function handleAboutImageUpload(event) {
            handleImageUpload(event, {
                compressFn: compressProduct,
                previewId: 'aboutImagePreview'
            }, function (dataUrl) {
                const data = getData();
                data.company.aboutImage = dataUrl;
                saveData(data);
            });
        }

        // Logo上传
        function handleLogoUpload(event) {
            handleImageUpload(event, {
                compressFn: compressLogo,
                previewId: 'logoPreview'
            }, function (dataUrl) {
                const data = getData();
                data.company.logo = dataUrl;
                saveData(data);
            });
        }
        function clearLogo() {
            try {
                if (!confirm('确定要移除Logo吗？')) return;
                const data = getData();
                data.company.logo = '';
                saveData(data);
                document.getElementById('logoPreview').style.display = 'none';
            } catch (err) {
                console.error(err);
                alert('操作失败：' + err.message);
            }
        }

        // 公众号二维码上传
        function handleWechatQrUpload(event) {
            handleImageUpload(event, {
                compressFn: compressQr,
                previewId: 'wechatQrPreview'
            }, function (dataUrl) {
                const data = getData();
                data.company.wechatQr = dataUrl;
                saveData(data);
            });
        }
        function clearWechatQr() {
            try {
                if (!confirm('确定要移除公众号二维码吗？')) return;
                const data = getData();
                data.company.wechatQr = '';
                saveData(data);
                document.getElementById('wechatQrPreview').style.display = 'none';
            } catch (err) {
                console.error(err);
                alert('操作失败：' + err.message);
            }
        }

        // 视频号二维码上传
        function handleVideoQrUpload(event) {
            handleImageUpload(event, {
                compressFn: compressQr,
                previewId: 'videoQrPreview'
            }, function (dataUrl) {
                const data = getData();
                data.company.videoQr = dataUrl;
                saveData(data);
            });
        }
        function clearVideoQr() {
            try {
                if (!confirm('确定要移除视频号二维码吗？')) return;
                const data = getData();
                data.company.videoQr = '';
                saveData(data);
                document.getElementById('videoQrPreview').style.display = 'none';
            } catch (err) {
                console.error(err);
                alert('操作失败：' + err.message);
            }
        }

        // 公司表单提交
        document.getElementById('companyForm').addEventListener('submit', function(e) {
            e.preventDefault();
            try {
                const data = getData();
                data.company.name = document.getElementById('companyName').value;
                data.company.phone = document.getElementById('companyPhone').value;
                data.company.email = document.getElementById('companyEmail').value;
                data.company.businessHours = document.getElementById('companyHours').value;
                data.company.address = document.getElementById('companyAddress').value;
                data.company.description = document.getElementById('companyDesc').value;
                // logo / 二维码 / 关于我们图片 均已在各自上传处理器中保存，这里再次同步一次
                data.company.aboutImage = data.company.aboutImage || '';
                data.company.logo = data.company.logo || '';
                data.company.wechatQr = data.company.wechatQr || '';
                data.company.videoQr = data.company.videoQr || '';
                saveData(data);
                alert('公司基本信息已保存！（图片/logo/二维码在上传时已自动保存）');
            } catch (err) {
                console.error(err);
                alert('保存公司信息失败：' + err.message);
            }
        });

        // 修改密码
        document.getElementById('passwordForm').addEventListener('submit', function(e) {
            e.preventDefault();
            try {
                const current = this.elements.currentPassword.value;
                const newPass = this.elements.newPassword.value;
                const confirmPass = this.elements.confirmPassword.value;

                let admin;
                try {
                    admin = JSON.parse(localStorage.getItem('hh_admin') || '{"username":"admin","password":"admin123"}');
                } catch (err) {
                    admin = { username: 'admin', password: 'admin123' };
                }

                if (current !== admin.password) {
                    alert('当前密码错误！');
                    return;
                }

                if (!newPass || newPass !== confirmPass) {
                    alert('两次输入的新密码不一致！');
                    return;
                }

                const newAdmin = Object.assign({}, admin, { password: newPass });
                localStorage.setItem('hh_admin', JSON.stringify(newAdmin));
                alert('密码修改成功！');
                this.reset();
            } catch (err) {
                console.error(err);
                alert('修改密码失败：' + err.message);
            }
        });

        // 重置数据
        function resetData() {
            if (confirm('确定要重置所有数据吗？这将恢复为默认内容，并清理后台本地存储。')) {
                // 为了避免之前上传的大图继续占用配额，先清理整个站点下的 hh_ 前缀 key
                try {
                    const keys = [];
                    for (let i = 0; i < localStorage.length; i++) {
                        const key = localStorage.key(i);
                        if (key && key.indexOf('hh_') === 0) {
                            keys.push(key);
                        }
                    }
                    keys.forEach(function (k) {
                        // 保留管理员会话 & 密码信息
                        if (k === 'hh_admin_session' || k === 'hh_admin') {
                            return;
                        }
                        localStorage.removeItem(k);
                    });
                } catch (err) {
                    console.error('清理旧数据失败：', err);
                }
                alert('数据已重置为默认值！现在可以重新上传图片了。');
                location.reload();
            }
        }

        // 初始化
        checkLogin();
        updateDashboard();
    </script>
</body>
</html>